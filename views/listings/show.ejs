<% layout("/layouts/boilerplate") %>
<body>
    <div class="row">
        <div class="col-8 offset-3 mt-3">
        <h3>Listing Details</h3>
        </div>

        <div class="card col-6 offset-3 show-card">
            <img src="<%= listing.image %>" class="card-img-top show-img" alt="listing_image">
            <div class="card-body">
                <p class="card-text">
                    <b>Title: <%= listing.title %></b><br>
                    <b>Description:</b> <%= listing.description %> <br>
                    <b>Price:</b> &#8377; <%= listing.price.toLocaleString("en-IN") %> <br>
                    <b>Location:</b> <%= listing.location %> <br>
                    <b>Country:</b> <%= listing.country %>
                </p>
            </div>
        </div>
    </div>
    <div class="btns">
        <a class="btn btn-dark col-1 offset-3 edit-btn" href="/listings/<%= listing._id %>/edit">Edit</a>

        <form method="post" action="/listings/<%= listing._id %>?_method=DELETE">
            <button class="btn btn-dark offset-5">Delete</button>
        </form>
    </div>
</body>